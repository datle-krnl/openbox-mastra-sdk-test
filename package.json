{
  "name": "@openbox-ai/openbox-mastra-sdk",
  "version": "0.1.0",
  "description": "OpenBox governance and observability SDK for Mastra",
  "license": "MIT",
  "author": "Shorya Singh (OpenBox Team)",
  "homepage": "https://github.com/OpenBox-AI/openbox-mastra-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenBox-AI/openbox-mastra-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/OpenBox-AI/openbox-mastra-sdk/issues"
  },
  "keywords": [
    "openbox",
    "mastra",
    "governance",
    "observability",
    "opentelemetry"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24.10.0"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./governance": {
      "types": "./dist/governance/index.d.ts",
      "import": "./dist/governance/index.js",
      "default": "./dist/governance/index.js"
    },
    "./mastra": {
      "types": "./dist/mastra/index.d.ts",
      "import": "./dist/mastra/index.js",
      "default": "./dist/mastra/index.js"
    },
    "./otel": {
      "types": "./dist/otel/index.d.ts",
      "import": "./dist/otel/index.js",
      "default": "./dist/otel/index.js"
    },
    "./span": {
      "types": "./dist/span/index.d.ts",
      "import": "./dist/span/index.js",
      "default": "./dist/span/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "ci:check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "clean": "rm -rf coverage dist",
    "example:quickstart": "npm run build && node ./examples/quickstart/index.mjs",
    "format": "prettier --write .",
    "lint": "eslint .",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mastra/core": "^1.8.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/instrumentation-cassandra-driver": "^0.52.0",
    "@opentelemetry/instrumentation-fs": "^0.26.0",
    "@opentelemetry/instrumentation-http": "^0.206.0",
    "@opentelemetry/instrumentation-ioredis": "^0.54.0",
    "@opentelemetry/instrumentation-knex": "^0.51.0",
    "@opentelemetry/instrumentation-mongodb": "^0.59.0",
    "@opentelemetry/instrumentation-mongoose": "^0.53.0",
    "@opentelemetry/instrumentation-mysql": "^0.52.0",
    "@opentelemetry/instrumentation-mysql2": "^0.53.0",
    "@opentelemetry/instrumentation-oracledb": "^0.32.0",
    "@opentelemetry/instrumentation-pg": "^0.59.0",
    "@opentelemetry/instrumentation-redis": "^0.55.0",
    "@opentelemetry/instrumentation-tedious": "^0.25.0",
    "@opentelemetry/instrumentation-undici": "^0.17.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.206.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/sdk-trace-node": "^2.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@mastra/core": "^1.8.0",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "msw": "^2.11.2",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vitest": "^3.2.4"
  }
}
